import random

def generate_maze(width=10, height=5):
    maze = [["#"]*width for _ in range(height)]
    for y in range(1, height-1):
        for x in range(1, width-1):
            maze[y][x] = " " if random.random() > 0.3 else "#"
    maze[1][1] = "S"
    maze[height-2][width-2] = "E"
    for row in maze:
        print("".join(row))

generate_maze()
